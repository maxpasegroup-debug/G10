PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_DB_HOST:5432/music_academy
JWT_SECRET=supersecretkey

# CORS: in development, * is fine. In production, set your real SPA origin(s):
#   FRONTEND_URL=https://your-app.vercel.app          ← easiest on Railway (backend service)
#   and/or CORS_ORIGIN=https://a.com,https://b.com
# Wildcard * alone in production will not start the server unless FRONTEND_URL/CLIENT_URL is set.
CORS_ORIGIN=*
# FRONTEND_URL=
# CLIENT_URL=

# Optional rate limits (per IP, per window)
# RATE_LIMIT_MAX_PER_WINDOW=300
# AUTH_RATE_LIMIT_MAX_PER_WINDOW=30
